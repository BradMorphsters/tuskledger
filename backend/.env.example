# ─────────────────────────────────────────────────────────────
#  Tusk Ledger — Backend Configuration Template
#  Copy this file to `.env` and fill in your own values.
#  NEVER commit the resulting .env — it's gitignored for a reason.
# ─────────────────────────────────────────────────────────────

# ─── Plaid credentials ──────────────────────────────────────
# Get yours at https://dashboard.plaid.com/developers/keys
# Sandbox keys are immediate; Production requires approval (see README).
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here

# Which Plaid environment these keys point at:
#   sandbox    — fake banks, free, use for first-run testing
#   production — real banks, requires Plaid approval
PLAID_ENV=sandbox

# ─── Session signing ────────────────────────────────────────
# Used to sign the auth-session cookie. If left blank, a fresh random
# key is generated on each backend start — fine for local-only use, but
# means you'll be logged out every restart. Set to a long random string
# (at least 32 chars) to keep sessions across restarts.
#
# Quick way to generate one:
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
SESSION_SECRET=

# ─── Sync schedule ──────────────────────────────────────────
# How often the background scheduler pulls fresh transactions / balances
# from every connected Plaid item. You can also click "Sync Now" any time.
SYNC_INTERVAL_HOURS=6

# ─── Webhooks (optional) ────────────────────────────────────
# Verify the Plaid-Verification JWT on incoming webhooks. Leave false
# for local dev where Plaid can't reach you anyway. Turn on once you've
# pointed Plaid at a stable public URL (e.g. via a tunnel).
PLAID_WEBHOOK_VERIFY=false

# ─── Development escape hatch ───────────────────────────────
# When true, the login page + MFA gate are bypassed entirely and every
# request is treated as authenticated. Useful for iterating on UI/API
# without re-entering TOTP on each restart.
#
# DO NOT set this in any environment that would be reachable from the
# public internet — it disables ALL auth.
DEV_BYPASS_AUTH=false

# ─── Encryption key (advanced) ──────────────────────────────
# By default, Plaid access tokens stored in SQLite are encrypted with a
# Fernet key auto-generated and saved to backend/.encryption_key on first
# run (chmod 600). Override below to use a different path or to inline the
# key (useful for CI / password-manager workflows).
# FINTRACK_ENCRYPTION_KEY_FILE=/absolute/path/to/your.key
# FINTRACK_ENCRYPTION_KEY=base64-fernet-key-here
